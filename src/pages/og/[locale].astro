---
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/inter';
import { getResume } from '../../content';
import { locales, type Locale } from '../../i18n';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const { basics } = getResume(locale);
const mark = basics.name.toLowerCase().replace(/\s+/g, '');
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <title>og-image source</title>
    <style>
      * {
        margin: 0;
        box-sizing: border-box;
      }
      body {
        width: 1200px;
        height: 630px;
        background: #fffdfa;
        color: #241d21;
        font-family: 'Inter Variable', Helvetica, Arial, sans-serif;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 80px;
        position: relative;
      }
      h1 {
        font-family: 'Bricolage Grotesque Variable', 'Arial Black', sans-serif;
        font-size: 110px;
        font-weight: 800;
        line-height: 1;
        letter-spacing: -0.02em;
      }
      h1 .dot {
        color: #e0186c;
      }
      .title {
        font-size: 38px;
        font-weight: 600;
        margin-top: 28px;
      }
      .tagline {
        font-style: italic;
        font-size: 32px;
        color: #6b6065;
        margin-top: 12px;
      }
      .sprinkles {
        position: absolute;
        bottom: 64px;
        left: 80px;
        display: flex;
        gap: 14px;
        align-items: center;
      }
      .sprinkles span {
        border-radius: 50%;
        display: inline-block;
      }
      .s1 {
        width: 26px;
        height: 26px;
        background: #e0186c;
      }
      .s2 {
        width: 20px;
        height: 20px;
        background: #7c3aed;
      }
      .s3 {
        width: 14px;
        height: 14px;
        background: #2f6bff;
      }
    </style>
  </head>
  <body>
    <h1>{mark}<span class="dot">.</span></h1>
    <p class="title">{basics.title}</p>
    <p class="tagline">{basics.tagline}</p>
    <div class="sprinkles"><span class="s1"></span><span class="s2"></span><span class="s3"></span></div>
  </body>
</html>
