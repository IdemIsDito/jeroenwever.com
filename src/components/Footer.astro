---
import { useTranslations, type Locale } from '../i18n';
import type { Resume } from '../content/schema';

interface Props {
  locale: Locale;
  basics: Resume['basics'];
}

const { locale, basics } = Astro.props;
const t = useTranslations(locale);
---

<footer>
  <p class="outro">
    {t('outro.line')} <a href={`mailto:${basics.email}`}>{basics.email}</a>
  </p>
  <p class="srd">
    {t('footer.builtWith')} — <a href="https://github.com/IdemIsDito/jeroenwever.com">{t('footer.source')}</a>.
    {basics.name} {t('footer.operatesAs')} <strong>Sugar Rush Development</strong> —
    <em>coding with the speed of sweet</em>
    <span class="sprinkles" aria-hidden="true">
      <span class="dot" style="--dot: var(--color-dot-raspberry)"></span>
      <span class="dot" style="--dot: var(--color-dot-grape)"></span>
      <span class="dot" style="--dot: var(--color-dot-blueberry)"></span>
    </span>
  </p>
</footer>

<style>
  footer {
    max-width: 44rem;
    margin-inline: auto;
    padding: var(--space-4) var(--page-pad) var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .outro {
    margin: 0;
  }

  .srd {
    margin: var(--space-3) 0 0;
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .sprinkles {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    margin-left: var(--space-1);

    & .dot:nth-child(2) {
      width: 0.4em;
      height: 0.4em;
    }

    & .dot:nth-child(3) {
      width: 0.3em;
      height: 0.3em;
    }
  }
</style>
