---
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<label class="theme">
  <span class="visually-hidden">{t('theme.legend')}</span>
  <select id="theme-select">
    <option value="system" selected>{t('theme.system')}</option>
    <option value="light">{t('theme.light')}</option>
    <option value="dark">{t('theme.dark')}</option>
  </select>
</label>

<script>
  const select = document.getElementById('theme-select') as HTMLSelectElement;

  const stored = localStorage.getItem('theme');
  select.value = stored === 'light' || stored === 'dark' ? stored : 'system';

  select.addEventListener('change', () => {
    const mode = select.value;
    if (mode === 'light' || mode === 'dark') {
      document.documentElement.dataset.theme = mode;
      localStorage.setItem('theme', mode);
    } else {
      delete document.documentElement.dataset.theme;
      localStorage.removeItem('theme');
    }
  });
</script>

<style>
  select {
    font: inherit;
    font-size: var(--text-sm);
    color: var(--color-text);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: var(--space-1) var(--space-2);
    min-height: 24px;
    cursor: pointer;

    &:hover {
      border-color: var(--color-accent);
    }
  }

  /* Customizable select where supported; native (still accessible) elsewhere. */
  @supports (appearance: base-select) {
    select,
    select::picker(select) {
      appearance: base-select;
    }

    select::picker(select) {
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: 10px;
      padding: var(--space-1);
      box-shadow: 0 6px 24px rgb(0 0 0 / 0.12);
    }

    option {
      padding: var(--space-1) var(--space-3);
      border-radius: 7px;

      &:hover,
      &:focus {
        background: var(--color-surface);
      }

      &:checked {
        color: var(--color-accent);
        font-weight: 600;
      }
    }
  }
</style>
