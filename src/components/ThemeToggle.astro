---
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<label class="theme">
  <span class="visually-hidden">{t('theme.legend')}</span>
  <select id="theme-select">
    <button>
      <span class="icon" aria-hidden="true">◐</span>
      <selectedcontent></selectedcontent>
    </button>
    <option value="system" selected>{t('theme.system')}</option>
    <option value="light">{t('theme.light')}</option>
    <option value="dark">{t('theme.dark')}</option>
  </select>
</label>

<script>
  const select = document.getElementById('theme-select') as HTMLSelectElement;

  const stored = localStorage.getItem('theme');
  select.value = stored === 'light' || stored === 'dark' ? stored : 'system';

  select.addEventListener('change', () => {
    const mode = select.value;
    if (mode === 'light' || mode === 'dark') {
      document.documentElement.dataset.theme = mode;
      localStorage.setItem('theme', mode);
    } else {
      delete document.documentElement.dataset.theme;
      localStorage.removeItem('theme');
    }
  });
</script>

<style>
  select {
    font: inherit;
    font-size: var(--text-sm);
    color: var(--color-text);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: var(--space-1) var(--space-2);
    min-height: 24px;
    cursor: pointer;

    &:hover {
      border-color: var(--color-accent);
    }
  }

  /* Customizable select where supported; native (still accessible) elsewhere. */
  @supports (appearance: base-select) {
    select,
    select::picker(select) {
      appearance: base-select;
    }

    select button {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-1);
      min-width: 24px;
      min-height: 24px;

      & .icon {
        color: var(--color-accent);
      }
    }

    /* Fixed trigger width so switching between values never shifts the topbar. */
    select selectedcontent {
      display: inline-block;
      min-inline-size: 4rem;
      text-align: start;
    }

    /* On narrow screens the trigger is icon-only; the open list still shows full labels. */
    @media (max-width: 40rem) {
      select selectedcontent {
        display: none;
      }
    }

    select::picker(select) {
      margin-block-start: var(--space-1);
      position-area: block-end span-inline-start;
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: 10px;
      padding: var(--space-1);
      box-shadow: 0 6px 24px rgb(0 0 0 / 0.12);
    }

    /* Layout only while open — an unconditional display would override the
       popover's closed state and render the list expanded on page load. */
    select:open::picker(select) {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    option {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-1) var(--space-2) var(--space-1) var(--space-3);
      border-radius: 7px;

      /* Trailing checkmark: text stays identically left-aligned on every option. */
      &::checkmark {
        order: 1;
        margin-inline-start: auto;
        color: var(--color-accent);
      }

      &:hover,
      &:focus {
        background: var(--color-surface);
      }

      &:checked {
        color: var(--color-accent);
        font-weight: 600;
      }
    }
  }
</style>
